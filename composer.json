{
    "name": "north-foundry/voyager-page-map-php",
    "description": "Deterministic HTML-first page maps for language models and browser agents.",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.3",
        "ext-dom": "*",
        "ext-libxml": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.5",
        "phpstan/phpstan": "^2.2",
        "friendsofphp/php-cs-fixer": "^3.95"
    },
    "autoload": {
        "psr-4": {
            "NorthFoundry\\VoyagerPageMap\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "NorthFoundry\\VoyagerPageMap\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "analyse": "phpstan analyse",
        "format": "php-cs-fixer fix",
        "format:check": "php-cs-fixer fix --dry-run --diff",
        "check": [
            "@format:check",
            "@analyse",
            "@test"
        ]
    },
    "config": {
        "sort-packages": true
    }
}
