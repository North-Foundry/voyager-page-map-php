VPM/1
title "Benefits - GOV.UK"
url https://www.gov.uk/browse/benefits

@e1 page [lang=en]
  @e2 a "Skip to main content" -> #content {?click, ?open}
  @e3 header
    @e4 nav "Navigation menu"
      @e5 a "Go to the GOV.UK homepage" -> ../../ {?click, ?open}
      @e6 h2 "Navigation menu"
      @e7 a "Menu" -> ../ {?click, ?open}
      @e8 a "Search GOV.UK" -> ../../search {?click, ?open}
  @e9 nav "Breadcrumb"
    @e10 ol
      @e11 li
        @e12 a "Home" -> ../../ {?click, ?open}
  @e13 main [lang=en]
    @e14 header
      @e15 h1 "Benefits"
      @e16 p "Includes eligibility, appeals, tax credits and Universal Credit"
    @e17 h2 "Most viewed"
    @e18 ul
      @e19 li
        @e20 a "Sign in to your Universal Credit account" -> ../../sign-in-universal-credit {?click, ?open}
      @e21 li
        @e22 a "Universal Credit" -> ../../universal-credit {?click, ?open}
      @e23 li
        @e24 a "Sign in to your childcare account" -> ../../sign-in-childcare-account {?click, ?open}
    @e25 h2 "Topics"
    @e26 ul
      @e27 li
        @e28 h3
          @e29 a "Manage an existing benefit, payment or claim" -> manage-your-benefit {?click, ?open}
        @e30 p "Sign in to your account, report changes, find out about overpayments, or appeal a decision. Includes existing Universal Credit and tax credits claims."
      @e31 li
        @e32 h3
          @e33 a "Benefits and financial support if you're looking for work" -> looking-for-work {?click, ?open}
        @e34 p "Help if you're looking for a new job, are out of work or affected by redundancy. Includes Universal Credit and Jobseeker’s Allowance (JSA)."
      @e35 li
        @e36 h3
          @e37 a "Benefits and financial support if you're temporarily unable to work" -> unable-to-work {?click, ?open}
        @e38 p "Help if you’re unable to work because you’re ill or self-isolating. Includes Universal Credit and Employment and Support Allowance (ESA)."
      @e39 li
        @e40 h3
          @e41 a "Benefits and financial support for families" -> families {?click, ?open}
        @e42 p "Help if you look after children or plan to have or adopt a child. Includes Child Benefit."
      @e43 li
        @e44 h3
          @e45 a "Benefits and financial support if you're disabled or have a health condition" -> disability {?click, ?open}
        @e46 p "Help if you're living with a health condition or disability. Includes Employment and Support Allowance (ESA)."
      @e47 li
        @e48 h3
          @e49 a "Benefits and financial support if you're caring for someone" -> help-for-carers {?click, ?open}
        @e50 p "Help if you regularly spend time caring for someone. Includes Universal Credit."
      @e51 li
        @e52 h3
          @e53 a "Benefits and financial support if you're on a low income" -> low-income {?click, ?open}
        @e54 p "Help with heating, housing and other living costs. Includes Universal Credit."
      @e55 li
        @e56 h3
          @e57 a "Benefits and financial support when someone dies" -> bereavement {?click, ?open}
        @e58 p "Help with costs and funeral expenses after someone has died. Includes Universal Credit."
